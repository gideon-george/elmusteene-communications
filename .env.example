# GitHub OAuth App credentials for the /admin content manager login.
# Create the OAuth App at https://github.com/settings/developers with
#   Homepage URL:      https://<your-domain>
#   Callback URL:      https://<your-domain>/api/callback
# then set these in Vercel → Project → Settings → Environment Variables.
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
